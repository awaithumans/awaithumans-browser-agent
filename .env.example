# ===========================================================================
# Pick ONE channel for the demo: slack OR email
# ===========================================================================

AWAITHUMANS_DEMO_CHANNEL=slack    # or "email"

# ===========================================================================
# awaithumans server (where tasks live)
# ===========================================================================
# Run locally with: docker compose up
AWAITHUMANS_URL=http://localhost:3001
AWAITHUMANS_API_KEY=dev-key-not-secret

# ===========================================================================
# LLM for the browser agent (pick ONE — OpenAI is the default)
# ===========================================================================
OPENAI_API_KEY=sk-...
# OR (uncomment to use Anthropic instead)
# ANTHROPIC_API_KEY=sk-ant-...

# ===========================================================================
# AI verifier (optional — pre-checks the human's response with Claude
# before paging them, so trivial requests don't interrupt people)
# ===========================================================================
ANTHROPIC_API_KEY=sk-ant-...

# ===========================================================================
# Slack channel (only needed if AWAITHUMANS_DEMO_CHANNEL=slack)
# ===========================================================================
# Create a Slack app at https://api.slack.com/apps, then:
# - Settings → Basic Information → App Credentials → Signing Secret
# - Features → OAuth & Permissions → OAuth Tokens → Bot Token (xoxb-...)
AWAITHUMANS_SLACK_BOT_TOKEN=xoxb-...
AWAITHUMANS_SLACK_SIGNING_SECRET=...

# Where to send the approval card — your Slack user ID (U...) or channel ID
DEMO_SLACK_NOTIFY_ID=U01234567

# ===========================================================================
# Email channel (only needed if AWAITHUMANS_DEMO_CHANNEL=email)
# ===========================================================================
# Resend is the easiest: https://resend.com (60-second signup, free dev tier)
AWAITHUMANS_SMTP_HOST=smtp.resend.com
AWAITHUMANS_SMTP_PORT=587
AWAITHUMANS_SMTP_USER=resend
AWAITHUMANS_SMTP_PASS=re_...
AWAITHUMANS_SMTP_FROM=onboarding@resend.dev

# Your email — where the magic-link approval lands
DEMO_EMAIL_NOTIFY=you@example.com

# ===========================================================================
# Demo store (the agent shops here)
# ===========================================================================
# We use saucedemo.com — the testing community's canonical practice site.
# Free, public, login credentials are intentionally publishable, no real
# money moves, no CAPTCHA. You can override these env vars to point at
# any other store you control.
SAUCEDEMO_URL=https://www.saucedemo.com
SAUCEDEMO_USERNAME=standard_user
SAUCEDEMO_PASSWORD=secret_sauce
